# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/helloavatar"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# App
PORT=4000
FRONTEND_URL="http://localhost:3000"
BACKEND_URL="http://localhost:4000/api"

# HeyGen
HEYGEN_API_KEY="your-heygen-api-key"

# ElevenLabs
ELEVENLABS_API_KEY="your-elevenlabs-api-key"

# AI (Groq – free at console.groq.com)
GROQ_API_KEY="gsk_your-groq-api-key"
EDGE_TTS_VOICE="en-US-JennyNeural"

# OpenAI (optional – only used as fallback)
OPENAI_API_KEY="sk-your-openai-api-key"

# AWS S3
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="helloavatar-uploads"

# Stripe
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret"
STRIPE_PRICE_STARTER="price_starter_id"
STRIPE_PRICE_PRO="price_pro_id"
STRIPE_PRICE_ENTERPRISE="price_enterprise_id"

# Groq (FREE Llama3 – replaces OpenAI for live chat)
GROQ_API_KEY="gsk_your-groq-api-key"

# Edge TTS voice (Microsoft free TTS – optional, defaults to en-US-JennyNeural)
# Full list: https://speech.microsoft.com/portal/voicegallery
EDGE_TTS_VOICE="en-US-JennyNeural"
